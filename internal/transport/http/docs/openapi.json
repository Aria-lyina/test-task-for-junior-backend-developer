{
  "openapi": "3.0.3",
  "info": {
    "title": "Task Service API",
    "version": "1.0.0",
    "description": "CRUD API for tasks with recurrence support."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Tasks",
      "description": "Operations with tasks"
    },
    {
      "name": "Periods",
      "description": "Reference data for recurrence periods"
    },
    {
      "name": "RepeatTasks",
      "description": "Recurrence task templates"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "List tasks",
        "responses": {
          "200": {
            "description": "Task list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Tasks"
        ],
        "summary": "Create task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "Get task by ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "Tasks"
        ],
        "summary": "Update task",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": [
          "Tasks"
        ],
        "summary": "Delete task",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/v1/tasks-with-repeat": {
      "get": {
        "tags": [
          "Tasks"
        ],
        "summary": "List tasks with recurrence info",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0,
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tasks with repeat info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskWithRepeatInfo"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Tasks"
        ],
        "summary": "Create task + repeat template atomically",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskWithRepeatRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created task and repeat template",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTaskWithRepeatResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/periods": {
      "get": {
        "tags": [
          "Periods"
        ],
        "summary": "List periods",
        "responses": {
          "200": {
            "description": "List of periods",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Period"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Periods"
        ],
        "summary": "Create period",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeriodMutation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created period",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Period"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/periods/{id}": {
      "get": {
        "tags": [
          "Periods"
        ],
        "summary": "Get period by ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Period",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Period"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "Periods"
        ],
        "summary": "Update period",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PeriodMutation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated period",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Period"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": [
          "Periods"
        ],
        "summary": "Delete period",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/v1/repeat-tasks": {
      "get": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "List all repeat task templates",
        "responses": {
          "200": {
            "description": "Active repeat tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RepeatTask"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Create repeat task template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RepeatTaskMutation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created repeat task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepeatTask"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/repeat-tasks/{id}": {
      "get": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Get repeat task by ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Repeat task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepeatTask"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Update repeat task template",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RepeatTaskMutation"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated repeat task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RepeatTask"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Delete repeat task template",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/v1/repeat-tasks/{id}/generate": {
      "post": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Generate tasks for a repeat template in date range",
        "parameters": [
          {
            "$ref": "#/components/parameters/ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateTasksRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Number of generated tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateTasksResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/v1/repeat-tasks/active": {
      "get": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "List active repeat task templates",
        "responses": {
          "200": {
            "description": "Active repeat tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RepeatTask"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tasks-generate": {
      "get": {
        "tags": [
          "RepeatTasks"
        ],
        "summary": "Generate tasks for all active repeat templates for today",
        "responses": {
          "200": {
            "description": "Number of generated tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateTasksResponse"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "ID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64",
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "CreateTaskRequest": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Подготовить отчёт"
          },
          "description": {
            "type": "string",
            "example": "Собрать данные за месяц"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "in_progress",
              "done"
            ],
            "example": "new"
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": [
          "title",
          "status"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Подготовить отчёт"
          },
          "description": {
            "type": "string",
            "example": "Собрать данные за месяц"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "in_progress",
              "done"
            ],
            "example": "in_progress"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Подготовить отчёт"
          },
          "description": {
            "type": "string",
            "example": "Собрать данные за месяц"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "in_progress",
              "done"
            ],
            "example": "new"
          },
          "repeat_task_id": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 3
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01T00:00:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01T00:00:00Z"
          }
        }
      },
      "Period": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "code": {
            "type": "string",
            "example": "daily"
          },
          "title": {
            "type": "string",
            "example": "Ежедневно"
          },
          "rrule_template": {
            "type": "string",
            "nullable": true,
            "example": "FREQ=DAILY"
          }
        }
      },
      "PeriodMutation": {
        "type": "object",
        "required": [
          "code",
          "title"
        ],
        "properties": {
          "code": {
            "type": "string",
            "example": "every_10_days"
          },
          "title": {
            "type": "string",
            "example": "Каждые 10 дней"
          },
          "rrule_template": {
            "type": "string",
            "nullable": true,
            "example": "FREQ=DAILY;INTERVAL=10"
          }
        }
      },
      "RepeatTaskMutation": {
        "type": "object",
        "required": [
          "title"
        ],
        "description": "Ровно одно из полей period_id, rrule или custom_dates должно быть заполнено",
        "properties": {
          "title": {
            "type": "string",
            "example": "Ежедневный обзвон пациентов"
          },
          "description": {
            "type": "string",
            "example": "Обзвонить пациентов из списка ожидания"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "in_progress",
              "done"
            ],
            "example": "new"
          },
          "period_id": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 1,
            "description": "ID периода из справочника. RRULE берётся автоматически."
          },
          "rrule": {
            "type": "string",
            "nullable": true,
            "example": "FREQ=DAILY;INTERVAL=3",
            "description": "Кастомное RRULE-правило. Используется если period_id не задан."
          },
          "custom_dates": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date",
              "example": "2026-05-01"
            },
            "nullable": true,
            "description": "Конкретные даты в формате YYYY-MM-DD. Используется если period_id и rrule не заданы."
          },
          "enabled": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "RepeatTask": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Ежедневный обзвон пациентов"
          },
          "description": {
            "type": "string",
            "example": "Обзвонить пациентов из списка ожидания"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "in_progress",
              "done"
            ],
            "example": "new"
          },
          "period_id": {
            "type": "integer",
            "format": "int64",
            "nullable": true,
            "example": 1
          },
          "rrule": {
            "type": "string",
            "nullable": true,
            "example": "FREQ=DAILY"
          },
          "custom_dates": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date"
            },
            "nullable": true,
            "example": [
              "2026-05-01",
              "2026-05-09"
            ]
          },
          "enabled": {
            "type": "boolean",
            "example": true
          },
          "last_generated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GenerateTasksRequest": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "format": "date",
            "example": "2026-05-01"
          },
          "to": {
            "type": "string",
            "format": "date",
            "example": "2026-05-31"
          }
        }
      },
      "GenerateTasksResponse": {
        "type": "object",
        "properties": {
          "generated": {
            "type": "integer",
            "example": 5
          }
        }
      },
      "TaskWithRepeatInfo": {
        "type": "object",
        "properties": {
          "task": {
            "$ref": "#/components/schemas/Task"
          },
          "repeat_task": {
            "$ref": "#/components/schemas/RepeatTask",
            "nullable": true
          },
          "period": {
            "$ref": "#/components/schemas/Period",
            "nullable": true
          }
        }
      },
      "CreateTaskWithRepeatRequest": {
        "type": "object",
        "required": [
          "repeat"
        ],
        "properties": {
          "task": {
            "$ref": "#/components/schemas/CreateTaskRequest"
          },
          "repeat": {
            "$ref": "#/components/schemas/RepeatTaskMutation"
          }
        }
      },
      "CreateTaskWithRepeatResponse": {
        "type": "object",
        "properties": {
          "task": {
            "$ref": "#/components/schemas/Task"
          },
          "repeat_task": {
            "$ref": "#/components/schemas/RepeatTask"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "task not found"
          }
        }
      }
    }
  }
}